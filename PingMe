[Mitm]
hostname = api.pingmeapp.net

[Script]
cron {cron} script-path=PingMe.js, img-url=https://raw.githubusercontent.com/fishdown/Icon/master/app/PingMe.png, timeout=60, enable={sw},tag=PingMe

http-request ^https:\/\/api\.pingmeapp\.net\/app\/queryBalanceAndBonus script-path=PingMe.js, requires-body=true, timeout=60, img-url=https://raw.githubusercontent.com/fishdown/Icon/master/app/PingMe.png, enable={sw2},tag=PingMe Cookie

[Argument]
sw=switch,true,tag=PingMe Cron,desc=开启日常签到与视频任务
sw2=switch,false,tag=PingMe Cookie,desc=开启获取Cookie抓包
cron = input, "30 8,20 * * *", tag=Cron时间, desc=执行时间设置
